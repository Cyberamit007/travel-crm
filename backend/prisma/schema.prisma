generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant / SaaS Foundation ───────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("FREE")    // FREE | STARTER | PRO | ENTERPRISE
  status    String   @default("ACTIVE")  // ACTIVE | SUSPENDED | CANCELLED
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  campaigns     Campaign[]
  leads         Lead[]
  tags          Tag[]
  leaveRequests LeaveRequest[]
  departments   Department[]

  @@map("organizations")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name         String
  email        String   @unique
  password     String
  role         String   @default("EMPLOYEE")   // ADMIN | EMPLOYEE
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true)
  availability String   @default("AVAILABLE")  // AVAILABLE | BUSY | OFFLINE
  lastLogin    DateTime?

  employeeId    String?      @unique
  departmentId  String?
  department    Department?  @relation("UserDepartment", fields: [departmentId], references: [id])
  designationId String?
  designation   Designation? @relation("UserDesignation", fields: [designationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedLeads       Lead[]             @relation("AssignedTo")
  campaignAssignments CampaignEmployee[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  feedbacks           Feedback[]
  refreshTokens       RefreshToken[]
  campaignNotes       CampaignNote[]
  campaignAttachments CampaignAttachment[]
  leaveRequests       LeaveRequest[]     @relation("EmployeeLeaves")
  approvedLeaves      LeaveRequest[]     @relation("ApprovedLeaves")
  leadComments        LeadComment[]
  headedDepartments   Department[]       @relation("DepartmentHead")

  @@index([organizationId])
  @@index([departmentId])
  @@index([designationId])
  @@map("users")
}

// ─── Auth: Refresh Tokens ────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique   // SHA-256 of the raw token (never store raw)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Campaigns ───────────────────────────────────────────────────────────────

model Campaign {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name        String
  destination String
  description String?
  status      String    @default("ACTIVE") // ACTIVE | PAUSED | DRAFT | ENDED
  startDate   DateTime?
  endDate     DateTime?
  targetLeads Int?
  budget      Float?

  whatsappNumber String?
  instagramAdId  String?
  utmSource      String?
  utmCampaign    String?
  keywords       String   @default("[]")

  // Meta Ads Manager sync fields
  metaCampaignId  String?   @unique
  metaAdAccountId String?
  metaObjective   String?
  metaStatus      String?               // Meta raw: ACTIVE | PAUSED | DELETED | ARCHIVED
  isFromMeta      Boolean   @default(false)
  lastSyncedAt    DateTime?
  archivedAt      DateTime?             // set after S3 upload completes
  archiveS3Key    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads       Lead[]
  employees   CampaignEmployee[]
  notes       CampaignNote[]
  attachments CampaignAttachment[]

  @@index([organizationId])
  @@index([status])
  @@map("campaigns")
}

model CampaignEmployee {
  id         String   @id @default(uuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  assignedAt DateTime @default(now())

  @@unique([campaignId, userId])
  @@map("campaign_employees")
}

model CampaignNote {
  id         String   @id @default(uuid())
  content    String
  isEdited   Boolean  @default(false)

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String

  author     User     @relation(fields: [authorId], references: [id])
  authorId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@map("campaign_notes")
}

model CampaignAttachment {
  id        String   @id @default(uuid())
  name      String
  fileUrl   String
  fileSize  Int
  mimeType  String

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String

  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  uploadedById String

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@map("campaign_attachments")
}

// ─── Leads ───────────────────────────────────────────────────────────────────

model Lead {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name  String
  phone String
  email String?

  source   String  @default("MANUAL")  // WHATSAPP | INSTAGRAM | MANUAL | WEBSITE
  status   String  @default("NEW")     // NEW | CONTACTED | INTERESTED | FOLLOW_UP_SCHEDULED | CONFIRMED | LOST
  priority String  @default("MEDIUM")  // HIGH | MEDIUM | LOW
  message  String?

  lostReason      String?
  lostReasonOther String?

  destination String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  campaignId  String?

  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String?

  followUpDate  DateTime?
  followUpNotes String?
  followUpDone  Boolean   @default(false)

  // Webhook tracking
  whatsappMsgId   String?
  instagramLeadId String?
  metaPageId      String?
  adId            String?
  adName          String?
  adsetId         String?               // Meta adset ID
  metaCampaignId  String?               // denormalized for archival queries

  notes         String?
  budget        Float?
  groupSize     Int?
  preferredDate String?

  isRead    Boolean   @default(false)
  deletedAt DateTime? // soft delete — null means active

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
  activityLogs  ActivityLog[]
  tags          LeadTag[]
  comments      LeadComment[]

  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([source])
  @@index([assignedToId])
  @@index([campaignId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([followUpDate])
  @@map("leads")
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id             String        @id @default(uuid())
  name           String
  color          String        @default("#6366f1") // hex color
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  leads LeadTag[]

  createdAt DateTime @default(now())

  @@unique([name, organizationId])
  @@index([organizationId])
  @@map("tags")
}

model LeadTag {
  id     String @id @default(uuid())
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
  @@map("lead_tags")
}

// ─── Lead Comments (Internal) ────────────────────────────────────────────────

model LeadComment {
  id       String  @id @default(uuid())
  content  String
  isEdited Boolean @default(false)

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  parent   LeadComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  parentId String?
  replies  LeadComment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([parentId])
  @@map("lead_comments")
}

// ─── Leave Requests ──────────────────────────────────────────────────────────

model LeaveRequest {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  startDate DateTime
  endDate   DateTime
  reason    String
  status    String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  adminNote String?

  employee   User   @relation("EmployeeLeaves", fields: [employeeId], references: [id])
  employeeId String

  approvedBy   User?   @relation("ApprovedLeaves", fields: [approvedById], references: [id])
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
  @@map("leave_requests")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id      String  @id @default(uuid())
  type    String
  title   String
  message String
  isRead  Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Activity Log ────────────────────────────────────────────────────────────

model ActivityLog {
  id         String  @id @default(uuid())
  action     String
  details    String?
  entityType String? // LEAD | CAMPAIGN | USER | LEAVE
  entityId   String?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([leadId])
  @@index([createdAt])
  @@index([entityType])
  @@map("activity_logs")
}

// ─── Webhooks ────────────────────────────────────────────────────────────────

model WebhookLog {
  id        String   @id @default(uuid())
  source    String
  payload   String
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  @@index([processed])
  @@map("webhook_logs")
}

// ─── Meta Ads Integration ────────────────────────────────────────────────────

model MetaConnection {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  adAccountId     String
  pageId          String?
  systemUserToken String                // AES-256-GCM encrypted at rest
  isActive        Boolean  @default(true)
  lastSyncAt      DateTime?
  lastSyncError   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("meta_connections")
}

model CampaignArchive {
  id             String   @id @default(cuid())
  organizationId String?
  metaCampaignId String
  campaignName   String
  leadCount      Int
  s3Key          String
  s3Bucket       String
  fileSizeBytes  Int?
  archivedAt     DateTime @default(now())

  @@index([organizationId])
  @@map("campaign_archives")
}

// ─── Feedback ────────────────────────────────────────────────────────────────

model Feedback {
  id          String  @id @default(uuid())
  type        String  // BUG | SUGGESTION | OTHER
  title       String
  description String
  page        String?
  priority    String  @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  status      String  @default("OPEN")   // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  adminNotes  String?

  submittedBy   User   @relation(fields: [submittedById], references: [id])
  submittedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feedback")
}

// ─── Organization Module ──────────────────────────────────────────────────────

model Department {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name        String
  code        String
  description String?
  headId      String?
  head        User?         @relation("DepartmentHead", fields: [headId], references: [id])
  status      String        @default("ACTIVE")  // ACTIVE | INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees    User[]        @relation("UserDepartment")
  designations Designation[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@map("departments")
}

model Designation {
  id           String     @id @default(uuid())
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String

  name        String
  description String?
  status      String     @default("ACTIVE")  // ACTIVE | INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees User[] @relation("UserDesignation")

  @@index([departmentId])
  @@map("designations")
}
