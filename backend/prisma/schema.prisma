generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant / SaaS Foundation ───────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("FREE")    // FREE | STARTER | PRO | ENTERPRISE
  status    String   @default("ACTIVE")  // ACTIVE | SUSPENDED | CANCELLED
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  campaigns     Campaign[]
  leads         Lead[]
  tags          Tag[]
  leaveRequests LeaveRequest[]
  departments   Department[]
  destinations  Destination[]
  tourCategories TourCategory[]
  packages      Package[]
  departures    Departure[]
  vendors       Vendor[]
  refunds       Refund[]
  vendorPayments VendorPayment[]
  expenses      Expense[]
  financeDocuments FinanceDocument[]

  @@map("organizations")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name         String
  email        String   @unique
  password     String
  role         String   @default("EMPLOYEE")   // ADMIN | EMPLOYEE | OPERATIONS | FINANCE
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true)
  availability String   @default("AVAILABLE")  // AVAILABLE | BUSY | OFFLINE
  lastLogin    DateTime?

  employeeId    String?      @unique
  departmentId  String?
  department    Department?  @relation("UserDepartment", fields: [departmentId], references: [id])
  designationId String?
  designation   Designation? @relation("UserDesignation", fields: [designationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedLeads       Lead[]             @relation("AssignedTo")
  campaignAssignments CampaignEmployee[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  feedbacks           Feedback[]
  refreshTokens       RefreshToken[]
  campaignNotes       CampaignNote[]
  campaignAttachments CampaignAttachment[]
  leaveRequests       LeaveRequest[]     @relation("EmployeeLeaves")
  approvedLeaves      LeaveRequest[]     @relation("ApprovedLeaves")
  leadComments        LeadComment[]
  headedDepartments   Department[]       @relation("DepartmentHead")
  recordedPayments    Payment[]          @relation("PaymentRecorder")
  assignedTasks       BookingTask[]      @relation("TaskAssignee")
  uploadedOpsDocuments OperationsDocument[] @relation("OpsDocumentUploader")
  opsNotes            OperationsNote[]   @relation("OpsNoteAuthor")
  updatedDepartureTasks DepartureTask[]  @relation("DepartureTaskUpdater")
  verifiedPayments     Payment[]        @relation("PaymentVerifier")
  requestedRefunds     Refund[]         @relation("RefundRequester")
  approvedRefunds      Refund[]         @relation("RefundApprover")
  createdVendorPayments VendorPayment[] @relation("VendorPaymentCreator")
  verifiedTravelers     Traveler[]      @relation("TravelerVerifier")
  uploadedVendorDocuments VendorDocument[] @relation("VendorDocumentUploader")
  createdExpenses       Expense[]       @relation("ExpenseCreator")
  approvedExpenses      Expense[]       @relation("ExpenseApprover")
  generatedFinanceDocuments FinanceDocument[] @relation("FinanceDocumentGenerator")
  updatedBusinessRules      BusinessRule[]    @relation("BusinessRuleUpdater")
  createdAutomationRules    AutomationRule[]  @relation("AutomationRuleCreator")

  @@index([organizationId])
  @@index([departmentId])
  @@index([designationId])
  @@map("users")
}

// ─── Auth: Refresh Tokens ────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique   // SHA-256 of the raw token (never store raw)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Campaigns ───────────────────────────────────────────────────────────────

model Campaign {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name        String
  destination String
  description String?
  status      String    @default("ACTIVE") // ACTIVE | PAUSED | DRAFT | ENDED
  startDate   DateTime?
  endDate     DateTime?
  targetLeads Int?
  budget      Float?

  whatsappNumber String?
  instagramAdId  String?
  utmSource      String?
  utmCampaign    String?
  keywords       String   @default("[]")

  // Meta Ads Manager sync fields
  metaCampaignId  String?   @unique
  metaAdAccountId String?
  metaObjective   String?
  metaStatus      String?               // Meta raw: ACTIVE | PAUSED | DELETED | ARCHIVED
  isFromMeta      Boolean   @default(false)
  lastSyncedAt    DateTime?
  archivedAt      DateTime?             // set after S3 upload completes
  archiveS3Key    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads       Lead[]
  employees   CampaignEmployee[]
  notes       CampaignNote[]
  attachments CampaignAttachment[]

  @@index([organizationId])
  @@index([status])
  @@map("campaigns")
}

model CampaignEmployee {
  id         String   @id @default(uuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  assignedAt DateTime @default(now())

  @@unique([campaignId, userId])
  @@map("campaign_employees")
}

model CampaignNote {
  id         String   @id @default(uuid())
  content    String
  isEdited   Boolean  @default(false)

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String

  author     User     @relation(fields: [authorId], references: [id])
  authorId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@map("campaign_notes")
}

model CampaignAttachment {
  id        String   @id @default(uuid())
  name      String
  fileUrl   String
  fileSize  Int
  mimeType  String

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String

  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  uploadedById String

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@map("campaign_attachments")
}

// ─── Leads ───────────────────────────────────────────────────────────────────

model Lead {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name  String
  phone String
  email String?

  source   String  @default("MANUAL")  // WHATSAPP | INSTAGRAM | MANUAL | WEBSITE
  status   String  @default("NEW")     // NEW | CONTACTED | INTERESTED | FOLLOW_UP_SCHEDULED | CONFIRMED | LOST
  priority String  @default("MEDIUM")  // HIGH | MEDIUM | LOW
  message  String?

  lostReason      String?
  lostReasonOther String?

  destination String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  campaignId  String?

  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String?

  followUpDate  DateTime?
  followUpNotes String?
  followUpDone  Boolean   @default(false)

  // Webhook tracking
  whatsappMsgId   String?
  instagramLeadId String?
  metaPageId      String?
  adId            String?
  adName          String?
  adsetId         String?               // Meta adset ID
  metaCampaignId  String?               // denormalized for archival queries

  notes         String?
  budget        Float?
  groupSize     Int?
  preferredDate String?

  // Customer profile fields (populated when lead becomes customer)
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRel   String?
  customerNotes         String?
  travelPreferences     String?   // JSON: { style, budget, frequency }

  isRead    Boolean   @default(false)
  deletedAt DateTime? // soft delete — null means active

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
  activityLogs  ActivityLog[]
  tags          LeadTag[]
  comments      LeadComment[]
  booking       Booking?

  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([source])
  @@index([assignedToId])
  @@index([campaignId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([followUpDate])
  @@map("leads")
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id             String        @id @default(uuid())
  name           String
  color          String        @default("#6366f1") // hex color
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  leads LeadTag[]

  createdAt DateTime @default(now())

  @@unique([name, organizationId])
  @@index([organizationId])
  @@map("tags")
}

model LeadTag {
  id     String @id @default(uuid())
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
  @@map("lead_tags")
}

// ─── Lead Comments (Internal) ────────────────────────────────────────────────

model LeadComment {
  id       String  @id @default(uuid())
  content  String
  isEdited Boolean @default(false)

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  parent   LeadComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  parentId String?
  replies  LeadComment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([parentId])
  @@map("lead_comments")
}

// ─── Leave Requests ──────────────────────────────────────────────────────────

model LeaveRequest {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  startDate DateTime
  endDate   DateTime
  reason    String
  status    String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  adminNote String?

  employee   User   @relation("EmployeeLeaves", fields: [employeeId], references: [id])
  employeeId String

  approvedBy   User?   @relation("ApprovedLeaves", fields: [approvedById], references: [id])
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
  @@map("leave_requests")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id      String  @id @default(uuid())
  type    String
  title   String
  message String
  isRead  Boolean @default(false)

  // Taxonomy layered on top of the existing free-string `type` — additive,
  // every pre-existing call site keeps working via the defaults below.
  // `channel` is architecture-ready only: non-IN_APP values are tagged for a
  // future integration but never actually dispatched outside this app today.
  category String? // SALES | OPERATIONS | FINANCE | CUSTOMER | SYSTEM
  severity String  @default("INFO") // INFO | REMINDER | SUCCESS | WARNING | CRITICAL
  channel  String  @default("IN_APP") // IN_APP | EMAIL | SMS | WHATSAPP

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId String?

  // Lets a click on the notification bell jump straight to the relevant trip
  // instead of only marking the notification read.
  departure   Departure? @relation(fields: [departureId], references: [id], onDelete: SetNull)
  departureId String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Activity Log ────────────────────────────────────────────────────────────

model ActivityLog {
  id         String  @id @default(uuid())
  action     String
  details    String?
  entityType String? // LEAD | CAMPAIGN | USER | LEAVE | DEPARTURE | HOTEL | VEHICLE | VENDOR | TRAVELER | PAYMENT | REFUND | VENDOR_PAYMENT | TRAVELER_PORTAL | VENDOR_DOCUMENT | EXPENSE
  entityId   String?

  // Before/after snapshot for a real audit diff — only populated at the
  // handful of highest-value mutation points (payment/refund/expense status
  // changes, booking edits), not every activityLog.create call in the app.
  oldValue Json?
  newValue Json?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([leadId])
  @@index([createdAt])
  @@index([entityType])
  @@map("activity_logs")
}

// ─── Webhooks ────────────────────────────────────────────────────────────────

model WebhookLog {
  id        String   @id @default(uuid())
  source    String
  payload   String
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  @@index([processed])
  @@map("webhook_logs")
}

// ─── Meta Ads Integration ────────────────────────────────────────────────────

model MetaConnection {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  adAccountId     String
  pageId          String?
  systemUserToken String                // AES-256-GCM encrypted at rest
  isActive        Boolean  @default(true)
  lastSyncAt      DateTime?
  lastSyncError   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("meta_connections")
}

model CampaignArchive {
  id             String   @id @default(cuid())
  organizationId String?
  metaCampaignId String
  campaignName   String
  leadCount      Int
  s3Key          String
  s3Bucket       String
  fileSizeBytes  Int?
  archivedAt     DateTime @default(now())

  @@index([organizationId])
  @@map("campaign_archives")
}

// ─── Feedback ────────────────────────────────────────────────────────────────

model Feedback {
  id          String  @id @default(uuid())
  type        String  // BUG | SUGGESTION | OTHER
  title       String
  description String
  page        String?
  priority    String  @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  status      String  @default("OPEN")   // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  adminNotes  String?

  submittedBy   User   @relation(fields: [submittedById], references: [id])
  submittedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feedback")
}

// ─── Organization Module ──────────────────────────────────────────────────────

model Department {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name        String
  code        String
  description String?
  headId      String?
  head        User?         @relation("DepartmentHead", fields: [headId], references: [id])
  status      String        @default("ACTIVE")  // ACTIVE | INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees    User[]        @relation("UserDepartment")
  designations Designation[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@map("departments")
}

model Designation {
  id           String     @id @default(uuid())
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String

  name        String
  description String?
  status      String     @default("ACTIVE")  // ACTIVE | INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees User[] @relation("UserDesignation")

  @@index([departmentId])
  @@map("designations")
}

// ─── Masters ──────────────────────────────────────────────────────────────────

model Destination {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name        String
  country     String
  state       String?
  city        String?
  type        String   @default("DOMESTIC")  // DOMESTIC | INTERNATIONAL
  description String?
  isPopular   Boolean  @default(false)
  status      String   @default("ACTIVE")    // ACTIVE | INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packages Package[]

  @@index([organizationId])
  @@index([status])
  @@map("destinations")
}

model TourCategory {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name        String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  status      String   @default("ACTIVE")  // ACTIVE | INACTIVE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packages Package[]

  @@index([organizationId])
  @@map("tour_categories")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id             String  @id @default(uuid())
  organizationId String?
  leadId         String  @unique
  lead           Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  bookingNumber     String?   @unique
  packageId         String?
  package           Package?  @relation(fields: [packageId], references: [id], onDelete: SetNull)

  travelerName      String
  numberOfTravelers Int
  aadharNumber      String?
  foodPreference    String  @default("NO_PREFERENCE") // VEG | NON_VEG | JAIN | NO_PREFERENCE
  roomSharing       String  @default("DOUBLE")        // SINGLE | DOUBLE | TRIPLE | QUAD
  departureLocation String?
  departurePackage  String?
  tourType          String  @default("GIT")           // FIT | GIT
  specialRequest    String?
  bookingNotes      String?

  departureDate DateTime?
  returnDate    DateTime?

  finalPrice     Float
  amountPaid     Float    @default(0)
  balanceAmount  Float    @default(0)
  balanceDueDate DateTime?

  salesExecutiveId String?
  opsExecutiveId   String?

  departureId String?
  departure   Departure? @relation(fields: [departureId], references: [id], onDelete: SetNull)

  // Traveler Portal — a per-booking secure link letting the customer submit
  // their own traveler details. Raw token is only ever returned once at
  // generation time; only its hash is stored (same idiom as RefreshToken).
  travelerPortalTokenHash      String?   @unique
  travelerPortalTokenExpiresAt DateTime?

  // Customer Journey Tracker terminal stages with no other backing field.
  reviewSubmittedAt   DateTime?
  referralReceivedAt  DateTime?

  status    String   @default("ACTIVE")  // ACTIVE | CANCELLED | COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments     Payment[]
  tasks        BookingTask[]
  travelers    Traveler[]
  refunds      Refund[]
  paymentSchedule PaymentScheduleItem[]
  financeDocuments FinanceDocument[]

  @@index([organizationId])
  @@index([leadId])
  @@index([packageId])
  @@index([departureDate])
  @@index([departureId])
  @@map("bookings")
}

// ─── Travelers (individual passengers within a booking) ──────────────────────
// Entered by Operations after a booking is confirmed — Sales only records a headcount.

model Traveler {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  name                  String
  mobile                String?
  email                 String?
  gender                String?   // MALE | FEMALE | OTHER
  dob                   DateTime?
  age                   Int?
  bloodGroup            String?
  nationality           String?
  seatNumber            String?
  pickupPoint           String?
  emergencyContactName  String?
  emergencyContactPhone String?
  roomSharing           String?   // overrides booking.roomSharing when set: SINGLE | DOUBLE | TRIPLE | QUAD
  foodPreference        String?   // overrides booking.foodPreference when set: VEG | NON_VEG | JAIN | NO_PREFERENCE
  isChild               Boolean  @default(false)
  isSeniorCitizen       Boolean  @default(false)
  needsExtraMattress    Boolean  @default(false)
  specialNotes          String?

  // Government ID — collected by the traveler themselves via the Traveler Portal
  govIdType             String?   // AADHAR | PASSPORT | VOTER_ID | DRIVING_LICENSE
  govIdNumber           String?
  govIdDocumentUrl      String?
  medicalConditions     String?
  arrivalDetails        String?   // free-text: flight/train number, arrival time
  departureDetails      String?   // free-text: return flight/train number, departure time

  // Flight vs. self-arranged travel — if not flying with us, Ops needs to know
  // whether pickup/drop transfer (usually included in the package) was opted
  // into, so it can be reflected under inclusions and staffed for.
  flightBookedByUs      Boolean?
  pickupDropBookedByUs  Boolean?

  // Traveler Portal verification workflow — Ops reviews what the customer submits.
  verificationStatus    String    @default("PENDING") // PENDING | SUBMITTED | VERIFIED | REJECTED | CORRECTION_REQUESTED
  verificationNote      String?
  submittedAt           DateTime?
  verifiedAt            DateTime?
  verifiedById          String?
  verifiedBy            User?     @relation("TravelerVerifier", fields: [verifiedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([verificationStatus])
  @@map("travelers")
}

// ─── Packages ─────────────────────────────────────────────────────────────────

model Package {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name        String
  code        String                              // e.g. "KED-6N7D-DEL"
  description String?
  overview    String?                             // rich overview / USP text

  destinationId  String?
  destination    Destination?  @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  tourCategoryId String?
  tourCategory   TourCategory? @relation(fields: [tourCategoryId], references: [id], onDelete: SetNull)

  nights     Int
  days       Int

  inclusions    String @default("[]")   // JSON array
  exclusions    String @default("[]")   // JSON array
  highlights    String @default("[]")   // JSON array
  thingsToCarry String @default("[]")   // JSON array

  pricePerPerson Float
  offerPrice     Float?                           // discounted/offer price
  priceSingle    Float?
  priceDouble    Float?
  priceTriple    Float?
  priceQuad      Float?

  capacityMin Int?                               // minimum group size
  capacityMax Int?                               // maximum group size

  difficultyLevel  String?                        // EASY | MODERATE | DIFFICULT | EXTREME
  bestSeason       String @default("[]")          // JSON array of months
  pickupLocation   String?
  dropLocation     String?

  cancellationPolicy  String?
  termsAndConditions  String?
  packageNotes        String?

  images  String @default("[]")                  // JSON array of image URLs
  gallery String @default("[]")                  // JSON array of gallery URLs

  isPopular Boolean @default(false)
  status    String  @default("ACTIVE")            // ACTIVE | INACTIVE | DRAFT

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itineraryItems PackageItinerary[]
  bookings       Booking[]
  departures     Departure[]
  expenses       Expense[]

  @@index([organizationId])
  @@index([destinationId])
  @@index([tourCategoryId])
  @@index([status])
  @@map("packages")
}

// ─── Package Itinerary (Day-Wise Workflow Template) ───────────────────────────

model PackageItinerary {
  id        String  @id @default(uuid())
  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  dayOffset   Int     // -15 = 15 days before trip, 0 = departure day, +2 = 2 days after
  title       String
  description String?
  notes       String?
  taskType    String  @default("GENERAL") // GENERAL | COLLECT_DOCS | COLLECT_PAYMENT | CONFIRM_HOTEL | CONFIRM_VEHICLE | SEND_REMINDER | TRIP_DAY | COLLECT_REVIEW | REFERRAL
  department  String  @default("SALES")   // SALES | OPERATIONS | CUSTOMER_CARE | ALL
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packageId])
  @@index([dayOffset])
  @@map("package_itineraries")
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  amount    Float
  type      String  @default("ADVANCE")       // ADVANCE | PARTIAL | FINAL | REFUND
  method    String  @default("CASH")          // CASH | UPI | BANK_TRANSFER | CHEQUE | ONLINE
  reference String?                           // UTR / cheque no / transaction ID
  notes     String?
  receiptNo String?
  proofUrl  String?                           // payment screenshot / proof upload

  // Finance verification workflow — a payment only credits booking.amountPaid
  // once VERIFIED (see payment.controller.ts). Sales records it as PENDING.
  status        String    @default("PENDING") // PENDING | VERIFIED | REJECTED | CORRECTION_REQUESTED
  financeNote   String?                       // rejection reason / correction request note
  verifiedById  String?
  verifiedBy    User?     @relation("PaymentVerifier", fields: [verifiedById], references: [id])
  verifiedAt    DateTime?

  recordedById String
  recordedBy   User   @relation("PaymentRecorder", fields: [recordedById], references: [id])

  // Optional tag for which installment this payment is meant to settle — purely
  // informational at recording time; the actual allocation (see approvePayment
  // in payment.controller.ts) always applies in schedule sequence order so a
  // lump-sum payment can still cover more than one installment.
  scheduleItemId String?
  scheduleItem   PaymentScheduleItem? @relation(fields: [scheduleItemId], references: [id], onDelete: SetNull)

  financeDocuments FinanceDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([bookingId])
  @@index([createdAt])
  @@index([status])
  @@map("payments")
}

// ─── Payment Schedule (installment plan) ─────────────────────────────────────
// Purely additive on top of Booking.balanceAmount/balanceDueDate, which keep
// working exactly as before — this is an informational/reminder-scheduling
// layer, auto-generated once at booking confirmation and editable afterward.
model PaymentScheduleItem {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  label      String                          // "Advance" | "Installment 1" | "Installment 2" | "Balance Payment"
  sequence   Int
  amount     Float
  dueDate    DateTime
  status     String  @default("PENDING")     // PENDING | PARTIAL | PAID — "overdue" is derived from dueDate at read time, not persisted
  paidAmount Float   @default(0)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([dueDate])
  @@index([status])
  @@map("payment_schedule_items")
}

// ─── Booking Tasks ────────────────────────────────────────────────────────────

model BookingTask {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  title       String
  description String?
  notes       String?
  dueDate     DateTime?
  dayOffset   Int?                             // from package itinerary
  taskType    String    @default("GENERAL")
  department  String    @default("SALES")      // SALES | OPERATIONS | CUSTOMER_CARE
  status      String    @default("PENDING")    // PENDING | IN_PROGRESS | DONE | SKIPPED
  priority    String    @default("MEDIUM")     // HIGH | MEDIUM | LOW

  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([status])
  @@map("booking_tasks")
}

// ─── Operations Panel ──────────────────────────────────────────────────────────
// Groups confirmed bookings that share a real-world trip departure. Created
// automatically when Sales confirms a booking (see booking.controller.ts) —
// Operations never creates one manually, only enriches it.

model Departure {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  packageId   String?
  package     Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  destination String                              // denormalized label for display/grouping
  departureDate DateTime
  returnDate    DateTime?

  status String @default("UPCOMING")              // UPCOMING | ACTIVE | COMPLETED | CANCELLED

  tripCaptainName   String?
  tripCaptainPhone  String?
  tripCaptainStatus String  @default("UNASSIGNED") // UNASSIGNED | ASSIGNED | CONFIRMED

  // Checklist Engine — only holds the handful of items with no natural backing
  // field (welcome kit, passenger list printed, emergency contacts, medical kit).
  // Every other checklist item is computed live from existing fields.
  manualChecklist Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  hotels    Hotel[]
  vehicles  Vehicle[]
  documents OperationsDocument[]
  notes     OperationsNote[]
  timeline  DepartureTask[]
  vendorPayments VendorPayment[]
  notifications  Notification[]
  expenses       Expense[]

  @@index([organizationId])
  @@index([packageId])
  @@index([departureDate])
  @@index([status])
  @@map("departures")
}

model Hotel {
  id          String    @id @default(uuid())
  departureId String
  departure   Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  name               String
  location           String?
  checkInDate        DateTime?
  checkOutDate       DateTime?
  numberOfRooms      Int?
  roomAllocation     String?                      // free-text summary, e.g. "5 Double, 2 Triple"
  vendorName         String?                      // legacy free-text — kept for backward compatibility
  vendorContact      String?
  vendorId           String?                      // optional FK to the Vendor master list (Vendor Workspace)
  vendor             Vendor? @relation("VendorHotels", fields: [vendorId], references: [id], onDelete: SetNull)
  confirmationNumber String?
  status             String  @default("PENDING")  // PENDING | CONFIRMED | CANCELLED
  voucherUrl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departureId])
  @@index([vendorId])
  @@map("operations_hotels")
}

model Vehicle {
  id          String    @id @default(uuid())
  departureId String
  departure   Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  vehicleType    String?
  vehicleNumber  String?
  driverName     String?
  driverMobile   String?
  pickupTime     DateTime?
  pickupLocation String?
  vendorName     String?                          // legacy free-text — kept for backward compatibility
  vendorContact  String?
  vendorId       String?                          // optional FK to the Vendor master list (Vendor Workspace)
  vendor         Vendor? @relation("VendorVehicles", fields: [vendorId], references: [id], onDelete: SetNull)
  status         String  @default("PENDING")      // PENDING | CONFIRMED | CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departureId])
  @@index([vendorId])
  @@map("operations_vehicles")
}

model Vendor {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name    String
  type    String  @default("OTHER")  // HOTEL | VEHICLE | LOCAL_GUIDE | LOCAL_VENDOR | OTHER
  contact String?
  notes   String?
  status  String  @default("ACTIVE") // ACTIVE | INACTIVE
  rating      Float?
  ratingCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments  VendorPayment[]
  hotels    Hotel[]         @relation("VendorHotels")
  vehicles  Vehicle[]       @relation("VendorVehicles")
  documents VendorDocument[]
  expenses  Expense[]

  @@index([organizationId])
  @@index([type])
  @@map("operations_vendors")
}

// Vendor-level documents (contracts, licenses, agreements) — distinct from
// OperationsDocument, which is scoped to a Departure, not a Vendor.
model VendorDocument {
  id       String @id @default(uuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  name     String
  type     String  @default("OTHER") // CONTRACT | LICENSE | AGREEMENT | OTHER
  fileUrl  String
  fileSize Int
  mimeType String

  uploadedById String
  uploadedBy   User   @relation("VendorDocumentUploader", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([vendorId])
  @@map("vendor_documents")
}

model OperationsDocument {
  id          String    @id @default(uuid())
  departureId String
  departure   Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  name     String
  type     String   @default("OTHER") // HOTEL_VOUCHER | VEHICLE_VOUCHER | CUSTOMER_LIST | ROOMING_LIST | TRIP_CAPTAIN_SHEET | EMERGENCY_CONTACT_LIST | VENDOR_BILL | OTHER
  fileUrl  String
  fileSize Int
  mimeType String

  uploadedById String
  uploadedBy   User   @relation("OpsDocumentUploader", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([departureId])
  @@map("operations_documents")
}

model OperationsNote {
  id          String    @id @default(uuid())
  departureId String
  departure   Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  content String

  authorId String
  author   User   @relation("OpsNoteAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@index([departureId])
  @@map("operations_notes")
}

model DepartureTask {
  id          String    @id @default(uuid())
  departureId String
  departure   Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  dayOffset   Int                                 // mirrors PackageItinerary.dayOffset relative to departureDate
  title       String
  description String?
  status      String  @default("PENDING")         // PENDING | IN_PROGRESS | COMPLETED
  sortOrder   Int     @default(0)

  updatedById String?
  updatedBy   User?   @relation("DepartureTaskUpdater", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departureId])
  @@map("departure_tasks")
}

// ─── Finance Panel ──────────────────────────────────────────────────────────
// Refunds are a dedicated workflow (Requested → Approved → Paid/Rejected),
// distinct from the ad-hoc Payment(type=REFUND) path — Finance uses this one.

model Refund {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  amount        Float
  reason        String
  status        String    @default("REQUESTED") // REQUESTED | APPROVED | PAID | REJECTED
  transactionId String?
  remarks       String?

  requestedById String
  requestedBy   User    @relation("RefundRequester", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?   @relation("RefundApprover", fields: [approvedById], references: [id])

  refundDate DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  financeDocuments FinanceDocument[]

  @@index([bookingId])
  @@index([organizationId])
  @@index([status])
  @@map("refunds")
}

// ─── Finance Documents (Invoice / Receipt / Credit Note / Debit Note / Refund
// Voucher) — persisted, numbered records so a document can always be looked
// up and re-downloaded later. snapshotJson freezes the customer/package/amount
// details at generation time so a later edit to the booking never retroactively
// rewrites a historical document. RECEIPT auto-generates when a payment is
// verified; REFUND_VOUCHER auto-generates when a refund is marked paid; the
// rest (TAX_INVOICE / CREDIT_NOTE / DEBIT_NOTE) are generated on demand.
model FinanceDocument {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  type           String                          // TAX_INVOICE | RECEIPT | CREDIT_NOTE | DEBIT_NOTE | REFUND_VOUCHER
  documentNumber String        @unique            // e.g. RCPT-2026-000042 — sequential per type per year

  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  refundId  String?
  refund    Refund?  @relation(fields: [refundId], references: [id], onDelete: SetNull)

  amount       Float
  taxAmount    Float  @default(0)
  status       String @default("GENERATED")      // GENERATED | CANCELLED
  pdfUrl       String?
  snapshotJson Json

  generatedById String
  generatedBy   User     @relation("FinanceDocumentGenerator", fields: [generatedById], references: [id])
  generatedAt   DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([type])
  @@index([organizationId])
  @@map("finance_documents")
}

// ─── Business Rules Engine ───────────────────────────────────────────────────
// Every threshold that used to be a hardcoded constant (advance %, reminder
// windows, escalation hours) reads from here via getRule()/getRuleNumber()
// (backend/src/services/businessRule.service.ts), falling back to that same
// original hardcoded value when no row exists — so behavior is unchanged
// until an Admin actually edits a rule.
model BusinessRule {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  category    String   // SALES | OPERATIONS | FINANCE | CUSTOMER | SYSTEM

  updatedById String?
  updatedBy   User?    @relation("BusinessRuleUpdater", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_rules")
}

// ─── Scheduled Job run history ───────────────────────────────────────────────
// One row per cron execution (backend/src/index.ts) — powers the System
// Health dashboard's Background Jobs / Failed Jobs widgets.
model ScheduledJobRun {
  id           String    @id @default(uuid())
  jobName      String
  startedAt    DateTime
  finishedAt   DateTime?
  status       String    @default("RUNNING") // RUNNING | SUCCESS | FAILED
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([jobName])
  @@index([createdAt])
  @@map("scheduled_job_runs")
}

// ─── Automation Builder ───────────────────────────────────────────────────────
// Form-based (not a drag-and-drop canvas) trigger/condition/action engine —
// additive on top of the existing hardcoded automation chains (createLead,
// createBooking's cascade), which are NOT modified or replaced. fireEvent()
// in automationEngine.service.ts is called as one more fire-and-forget step
// at the end of those flows.
model AutomationRule {
  id            String  @id @default(uuid())
  name          String
  triggerType   String                        // LEAD_CREATED | BOOKING_CONFIRMED | PAYMENT_OVERDUE | TASK_OVERDUE | TRAVELER_VERIFICATION_PENDING | HOTEL_PENDING | VEHICLE_PENDING
  triggerConfig Json    @default("{}")
  conditions    Json    @default("[]")         // [{ field, operator, value }]
  actions       Json    @default("[]")         // [{ type, config }]
  delayMinutes  Int?
  isActive      Boolean @default(true)

  createdById String
  createdBy   User   @relation("AutomationRuleCreator", fields: [createdById], references: [id])

  executions AutomationExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([triggerType, isActive])
  @@map("automation_rules")
}

// Makes "Delay" + "Next Action" work without a real job queue — a cron sweep
// (processDueAutomationExecutions) executes rows whose scheduledFor has passed.
model AutomationExecution {
  id             String   @id @default(uuid())
  ruleId         String
  rule           AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  triggerContext Json
  status         String   @default("PENDING") // PENDING | EXECUTED | CANCELLED | FAILED
  scheduledFor   DateTime
  executedAt     DateTime?
  errorMessage   String?

  createdAt DateTime @default(now())

  @@index([status, scheduledFor])
  @@map("automation_executions")
}

// ─── Error Log ────────────────────────────────────────────────────────────────
// Populated only by the global Express error-handling middleware (index.ts),
// only for 500-level responses — powers System Health's "Recent Errors"
// widget. Not full APM; userId is informational only (no FK, same loose
// convention as ActivityLog.entityId) since errors can occur for
// unauthenticated requests too.
model ErrorLog {
  id         String   @id @default(uuid())
  message    String
  stack      String?
  path       String?
  method     String?
  statusCode Int?
  userId     String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("error_logs")
}

// Transactional vendor bills — a Vendor (master record) can have many of these
// across many departures. Not fields on Vendor itself.

model VendorPayment {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  departureId String?
  departure   Departure? @relation(fields: [departureId], references: [id], onDelete: SetNull)

  serviceType String                          // HOTEL | VEHICLE | TRIP_CAPTAIN | LOCAL_GUIDE | LOCAL_VENDOR | ACTIVITY
  totalAmount Float
  advancePaid Float    @default(0)
  balanceAmount Float  @default(0)
  dueDate     DateTime?
  status      String   @default("PENDING")    // PENDING | PARTIAL | PAID | OVERDUE
  invoiceUrl  String?
  paymentProofUrl String?
  notes       String?

  createdById String
  createdBy   User   @relation("VendorPaymentCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([departureId])
  @@index([organizationId])
  @@index([status])
  @@map("vendor_payments")
}

// ─── Expense Management ────────────────────────────────────────────────────
// Non-vendor-bill costs: trip-scoped categories (meals, permits, fuel, misc)
// and company overhead (office, marketing, salary, software, utilities).
// departureId/packageId are both optional — null departureId means company
// overhead, which is tracked for the Expense Report but never allocated to
// any trip's profitability (that would require an arbitrary allocation rule).
model Expense {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  category    String          // HOTEL | VEHICLE | DRIVER | GUIDE | MEALS | PERMITS | FUEL | MISCELLANEOUS | OFFICE | MARKETING | SALARY | SOFTWARE | UTILITIES
  amount      Float
  description String?

  departureId String?
  departure   Departure? @relation(fields: [departureId], references: [id], onDelete: SetNull)
  packageId   String?
  package     Package?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  vendorId    String?
  vendor      Vendor?    @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  billUrl String?

  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedById String?
  approvedBy   User?     @relation("ExpenseApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  rejectionReason String?

  createdById String
  createdBy   User   @relation("ExpenseCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([departureId])
  @@index([packageId])
  @@index([category])
  @@index([status])
  @@map("expenses")
}
